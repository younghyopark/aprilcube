<?xml version="1.0" encoding="UTF-8"?>
<mujoco model="aruco_cube">
  <!-- Box: 110 x 110 x 40 mm -->
  <!-- Origin at cube center, XYZ axes match detect_cube.py -->
  <!-- Units: meters -->

  <compiler angle="radian" meshdir="."/>

  <asset>
    <texture name="cube_tex" type="2d" file="cube_atlas.png"/>
    <material name="cube_mat" texture="cube_tex" specular="0.1" shininess="0.1"/>
    <mesh name="cube_mesh" file="cube.obj"/>
  </asset>

  <worldbody>
    <body name="cube" pos="0 0 0">
      <freejoint name="cube_joint"/>
      <geom name="cube_visual" type="mesh" mesh="cube_mesh" material="cube_mat" contype="0" conaffinity="0" group="1" density="0"/>
      <geom name="cube_collision" type="box" size="0.055000 0.055000 0.020000" density="1250" rgba="0.5 0.5 0.5 0" contype="1" conaffinity="1" group="2"/>
      <site name="cube_center" pos="0 0 0" size="0.001"/>
    </body>
  </worldbody>
</mujoco>
